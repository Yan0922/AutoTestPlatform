# 复制为 .env 后按需修改

# 临时文件目录（系统盘 /tmp 满时必须配置到 NAS 等可写路径）
# 影响：模型远程下载解压、Python tempfile、以及通过 dev_backend.sh 启动时的 shell
PLATFORM_TEMP_DIR=/nasStore/yanliuping/tmp

DJANGO_SECRET_KEY=please-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# 数据库（默认 mysql；如果不想装 MySQL 可以临时改为 sqlite）
DB_ENGINE=mysql
DB_NAME=algotest
DB_USER=algotest
DB_PASSWORD=algotest123
DB_HOST=127.0.0.1
DB_PORT=3306

# Celery（如未单独部署，可保持默认本地 redis）
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_ALWAYS_EAGER=1

# 远程 ASR 模型下载根地址（模型管理 -> 下载模型）
# 示例: http://192.168.0.100:8080/k2/asr
ASR_MODEL_REMOTE_BASE_URL=

# K2 测试引擎（测试任务管理 -> 真实 ASR 推理）
# 本地 Windows 通常保持 0（走模拟推理）；Linux 服务器上设为 1 并配置 testAsr 路径
K2_ENGINE_ENABLED=0
# 可选，默认自动识别为 <项目根>/model-test
# K2_PROJECT_ROOT=D:\Projects\AutoTestPlatform\model-test
# 可选，默认 backend/media/k2_staging
# K2_STAGING_DIR=
# Linux 服务器上 testAsr 可执行文件路径（可选，默认同 k2_asr_model_test/testAsr）
# TESTASR_BIN=/path/to/k2_asr_model_test/testAsr
